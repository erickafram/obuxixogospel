<%- include('../partials/header', { title: 'Páginas', user: user }) %>

<div class="dashboard-content">
    <div class="content-header">
        <div>
            <h1>Páginas</h1>
            <p>Gerencie as páginas estáticas do site</p>
        </div>
        <a href="/dashboard/paginas/novo" class="btn btn-primary">
            <i class="fas fa-plus"></i> Nova Página
        </a>
    </div>

    <div class="card">
        <div class="card-header">
            <div class="search-filter">
                <input type="text" id="searchPaginas" placeholder="Buscar páginas..." class="search-input">
            </div>
        </div>

        <div class="table-responsive">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Título</th>
                        <th>Slug</th>
                        <th>Ordem</th>
                        <th>Footer</th>
                        <th>Menu</th>
                        <th>Status</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (pages && pages.length > 0) { %>
                        <% pages.forEach(page => { %>
                        <tr>
                            <td><%= page.titulo %></td>
                            <td><code><%= page.slug %></code></td>
                            <td><%= page.ordem %></td>
                            <td>
                                <% if (page.exibirFooter) { %>
                                <span class="badge badge-success">Sim</span>
                                <% } else { %>
                                <span class="badge badge-secondary">Não</span>
                                <% } %>
                            </td>
                            <td>
                                <% if (page.exibirMenu) { %>
                                <span class="badge badge-success">Sim</span>
                                <% } else { %>
                                <span class="badge badge-secondary">Não</span>
                                <% } %>
                            </td>
                            <td>
                                <% if (page.ativo) { %>
                                <span class="badge badge-success">Ativo</span>
                                <% } else { %>
                                <span class="badge badge-secondary">Inativo</span>
                                <% } %>
                            </td>
                            <td>
                                <div class="action-buttons">
                                    <a href="/pagina/<%= page.slug %>" target="_blank" class="btn-icon" title="Ver">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a href="/dashboard/paginas/<%= page.id %>/editar" class="btn-icon" title="Editar">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <button onclick="deletarPagina(<%= page.id %>, '<%= page.titulo %>')" class="btn-icon btn-danger" title="Deletar">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                        <% }); %>
                    <% } else { %>
                        <tr>
                            <td colspan="7" class="text-center">Nenhuma página encontrada</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .content-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 20px;
        padding-bottom: 18px;
        border-bottom: 1px solid #E2E8F0;
    }

    .content-header h1 {
        font-size: 22px;
        font-weight: 600;
        margin-bottom: 5px;
        color: #1A202C;
        letter-spacing: -0.5px;
    }

    .content-header p {
        color: #718096;
        font-size: 13px;
        margin: 0;
    }

    .btn {
        padding: 9px 16px;
        border-radius: 8px;
        font-weight: 500;
        font-size: 13px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 7px;
        transition: all 0.15s;
        border: none;
        cursor: pointer;
        letter-spacing: 0.2px;
    }

    .btn-primary {
        background: linear-gradient(135deg, #FF6B00 0%, #FF8533 100%);
        color: white;
        box-shadow: 0 2px 6px rgba(255, 107, 0, 0.2);
    }

    .btn-primary:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 10px rgba(255, 107, 0, 0.3);
    }

    .card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 1px 2px rgba(0,0,0,0.06);
        border: 1px solid #E8E8E8;
        overflow: hidden;
    }

    .card-header {
        padding: 16px 18px;
        border-bottom: 1px solid #E2E8F0;
        background: #FAFBFC;
    }

    .search-filter {
        display: flex;
        gap: 10px;
    }

    .search-input {
        flex: 1;
        padding: 8px 12px;
        border: 1px solid #E2E8F0;
        border-radius: 8px;
        font-size: 13px;
        transition: all 0.15s;
        background: white;
    }

    .search-input:focus {
        outline: none;
        border-color: #FF6B00;
        box-shadow: 0 0 0 3px rgba(255, 107, 0, 0.06);
    }

    .table-responsive {
        overflow-x: auto;
    }

    .data-table {
        width: 100%;
        border-collapse: collapse;
    }

    .data-table th {
        padding: 12px 14px;
        text-align: left;
        font-weight: 500;
        font-size: 11px;
        color: #4A5568;
        text-transform: uppercase;
        letter-spacing: 0.6px;
        background: #F7FAFC;
        border-bottom: 1px solid #E2E8F0;
    }

    .data-table td {
        padding: 12px 14px;
        border-bottom: 1px solid #E2E8F0;
        font-size: 13px;
        color: #2D3748;
    }

    .data-table tr:hover {
        background: #F7FAFC;
    }

    .data-table code {
        background: #F7FAFC;
        padding: 3px 8px;
        border-radius: 4px;
        font-size: 12px;
        color: #FF6B00;
        font-family: 'Courier New', monospace;
    }

    .badge {
        padding: 3px 8px;
        border-radius: 5px;
        font-size: 10px;
        font-weight: 500;
        text-transform: uppercase;
        display: inline-block;
        letter-spacing: 0.3px;
    }

    .badge-success { background: #D4EDDA; color: #155724; }
    .badge-secondary { background: #E2E3E5; color: #383D41; }

    .action-buttons {
        display: flex;
        gap: 6px;
    }

    .btn-icon {
        width: 30px;
        height: 30px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 6px;
        background: #F7FAFC;
        color: #718096;
        border: none;
        cursor: pointer;
        transition: all 0.15s;
        text-decoration: none;
        font-size: 13px;
    }

    .btn-icon:hover {
        background: #EDF2F7;
        color: #2D3748;
        transform: scale(1.05);
    }

    .btn-icon.btn-danger:hover {
        background: #FEE2E2;
        color: #DC2626;
    }

    .text-center {
        text-align: center;
        padding: 32px !important;
        color: #9CA3AF;
        font-size: 13px;
    }
</style>

<script>
    // Filtro de busca
    document.getElementById('searchPaginas').addEventListener('input', function() {
        const searchTerm = this.value.toLowerCase();
        const rows = document.querySelectorAll('.data-table tbody tr');
        
        rows.forEach(row => {
            const titulo = row.querySelector('td:nth-child(1)')?.textContent.toLowerCase() || '';
            const slug = row.querySelector('td:nth-child(2)')?.textContent.toLowerCase() || '';
            
            if (titulo.includes(searchTerm) || slug.includes(searchTerm)) {
                row.style.display = '';
            } else {
                row.style.display = 'none';
            }
        });
    });

    function deletarPagina(id, titulo) {
        if (confirm(`Tem certeza que deseja deletar a página "${titulo}"?`)) {
            fetch(`/dashboard/paginas/${id}`, {
                method: 'DELETE'
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    location.reload();
                } else {
                    alert('Erro ao deletar página');
                }
            });
        }
    }
</script>

<%- include('../partials/footer') %>
