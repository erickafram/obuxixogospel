<%- include('../partials/header', { title: 'Posts', user: user }) %>

<div class="dashboard-content">
    <div class="content-header">
        <div>
            <h1>Posts</h1>
            <p>Gerencie todos os artigos do portal</p>
        </div>
        <a href="/dashboard/posts/novo" class="btn btn-primary">
            <i class="fas fa-plus"></i> Novo Post
        </a>
    </div>

    <% if (typeof success !== 'undefined' && success) { %>
    <div class="alert alert-success">
        <%= success %>
    </div>
    <% } %>

    <div class="card">
        <div class="card-header">
            <div class="search-filter">
                <input type="text" id="searchPosts" placeholder="Buscar posts..." class="search-input">
                <select id="filterCategoria" class="filter-select">
                    <option value="">Todas as categorias</option>
                    <option value="g1">Notícias</option>
                    <option value="ge">Música</option>
                    <option value="gshow">Eventos</option>
                    <option value="quem">Ministérios</option>
                    <option value="valor">Estudos</option>
                </select>
            </div>
        </div>

        <div class="table-responsive">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Título</th>
                        <th>Categoria</th>
                        <th>Autor</th>
                        <th>Visualizações</th>
                        <th>Data</th>
                        <th>Status</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (articles && articles.length > 0) { %>
                        <% 
                        const categoryNames = {
                            'g1': 'Notícias',
                            'ge': 'Música', 
                            'gshow': 'Eventos',
                            'quem': 'Ministérios',
                            'valor': 'Estudos'
                        };
                        %>
                        <% articles.forEach(article => { %>
                        <tr>
                            <td>
                                <div class="post-title">
                                    <% if (article.destaque) { %>
                                    <span class="badge badge-warning">Destaque</span>
                                    <% } %>
                                    <%= article.titulo %>
                                </div>
                            </td>
                            <td><span class="badge badge-<%= article.categoria %>"><%= categoryNames[article.categoria] || article.categoria %></span></td>
                            <td><%= article.autor %></td>
                            <td><i class="fas fa-eye"></i> <%= article.visualizacoes %></td>
                            <td><%= new Date(article.dataPublicacao).toLocaleDateString('pt-BR') %></td>
                            <td>
                                <% if (article.publicado) { %>
                                <span class="badge badge-success">Publicado</span>
                                <% } else { %>
                                <span class="badge badge-secondary">Rascunho</span>
                                <% } %>
                            </td>
                            <td>
                                <div class="action-buttons">
                                    <a href="/noticia/<%= article.urlAmigavel %>" target="_blank" class="btn-icon" title="Ver">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a href="/dashboard/posts/editar/<%= article.id %>" class="btn-icon" title="Editar">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <button onclick="deletePost(<%= article.id %>)" class="btn-icon btn-danger" title="Deletar">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                        <% }); %>
                    <% } else { %>
                        <tr>
                            <td colspan="7" class="text-center">Nenhum post encontrado</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .content-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 24px;
    }

    .content-header h1 {
        font-size: 28px;
        font-weight: 700;
        margin-bottom: 4px;
    }

    .content-header p {
        color: #666;
        font-size: 14px;
    }

    .btn {
        padding: 10px 20px;
        border-radius: 8px;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.2s;
        border: none;
        cursor: pointer;
    }

    .btn-primary {
        background: #FF6B00;
        color: white;
    }

    .btn-primary:hover {
        background: #E65C00;
        transform: translateY(-1px);
    }

    .card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.06);
        overflow: hidden;
    }

    .card-header {
        padding: 20px;
        border-bottom: 1px solid #E0E0E0;
    }

    .search-filter {
        display: flex;
        gap: 12px;
    }

    .search-input, .filter-select {
        padding: 10px 16px;
        border: 2px solid #E0E0E0;
        border-radius: 8px;
        font-size: 14px;
    }

    .search-input {
        flex: 1;
    }

    .filter-select {
        min-width: 200px;
    }

    .table-responsive {
        overflow-x: auto;
    }

    .data-table {
        width: 100%;
        border-collapse: collapse;
    }

    .data-table th {
        padding: 16px;
        text-align: left;
        font-weight: 600;
        font-size: 13px;
        color: #666;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        background: #F5F7FA;
    }

    .data-table td {
        padding: 16px;
        border-bottom: 1px solid #E0E0E0;
    }

    .data-table tr:hover {
        background: #F9FAFB;
    }

    .post-title {
        font-weight: 500;
        color: #1a1a1a;
    }

    .badge {
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        display: inline-block;
    }

    .badge-success { background: #D4EDDA; color: #155724; }
    .badge-secondary { background: #E2E3E5; color: #383D41; }
    .badge-warning { background: #FFF3CD; color: #856404; margin-right: 8px; }
    .badge-g1 { background: #FFE5E5; color: #C1121F; }
    .badge-ge { background: #D4EDDA; color: #28A745; }
    .badge-gshow { background: #FFE8D6; color: #FF8C42; }
    .badge-quem { background: #F3E5F5; color: #8B3A62; }
    .badge-valor { background: #E3F2FD; color: #1F4788; }

    .action-buttons {
        display: flex;
        gap: 8px;
    }

    .btn-icon {
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 6px;
        background: #F5F7FA;
        color: #666;
        border: none;
        cursor: pointer;
        transition: all 0.2s;
        text-decoration: none;
    }

    .btn-icon:hover {
        background: #E8EBF0;
        color: #1a1a1a;
    }

    .btn-icon.btn-danger:hover {
        background: #FEE;
        color: #C33;
    }

    .alert {
        padding: 14px 16px;
        border-radius: 8px;
        margin-bottom: 24px;
        font-size: 14px;
    }

    .alert-success {
        background: #D4EDDA;
        color: #155724;
        border: 1px solid #C3E6CB;
    }

    .text-center {
        text-align: center;
        padding: 40px !important;
        color: #999;
    }
</style>

<script>
    function deletePost(id) {
        if (confirm('Tem certeza que deseja deletar este post?')) {
            fetch(`/dashboard/posts/deletar/${id}`, {
                method: 'DELETE'
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    location.reload();
                } else {
                    alert('Erro ao deletar post');
                }
            });
        }
    }
</script>

<%- include('../partials/footer') %>
